[Proxy]
# Использовать прокси (true/false)
# Use proxy (true/false)
enabled = false

# Тип прокси (socks5/socks4/http)
# Proxy type (socks5/socks4/http)
type = socks5

# Адрес прокси сервера
# Proxy server address
host = 127.0.0.1

# Порт прокси сервера
# Proxy server port
port = 1080

# Имя пользователя (оставьте пустым если не требуется)
# Username (leave empty if not required)
username = 

# Пароль (оставьте пустым если не требуется)
# Password (leave empty if not required)
password = 

[ProxyRotation]
# Ротация прокси (true/false)
# Proxy rotation (true/false)
rotation_enabled = false

# Интервал ротации в секундах
# Rotation interval in seconds
rotation_interval = 3600

# Список прокси для ротации (формат: type://host:port или type://user:pass@host:port)
# Proxy list for rotation (format: type://host:port or type://user:pass@host:port)
# Пример / Example:
# proxy_list = 
#     socks5://127.0.0.1:1080
#     socks5://user:pass@proxy.example.com:1080
#     http://proxy2.example.com:8080
proxy_list = 

[MTProto]
# Использовать MTProto прокси (true/false)
# Use MTProto proxy (true/false)
mtproto_enabled = false

# MTProto прокси сервер
# MTProto proxy server
mtproto_host = 

# MTProto прокси порт
# MTProto proxy port
mtproto_port = 443

# MTProto secret (в hex формате)
# MTProto secret (in hex format)
mtproto_secret = 
